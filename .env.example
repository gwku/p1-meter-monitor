# P1 Meter API
P1_API_URL=http://192.168.178.43/api/v1/data

# Data Collection
COLLECTION_INTERVAL=60

# Email Configuration
P1_EMAIL_TO=your-email@example.com,your-email2@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TLS=yes

# Automation
ENABLE_MONTHLY_REPORT=true
ENABLE_WEEKLY_EXPORT=false
